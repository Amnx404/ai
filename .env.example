# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/roboracer"

# NextAuth
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Scraper pipeline callback base URL (PUBLIC, but server-only env var):
# the pipeline uses this to POST back to:
#   /api/v1/knowledge-base/run/callback?siteId=...&clientRequestId=...
# Example: https://app.yourdomain.com
callback_URL="http://localhost:3000"

# Resend (email magic link)
RESEND_API_KEY=""
# Optional. Must be a sender Resend allows (verified domain or Resend onboarding address).
RESEND_FROM="RoboRacer <onboarding@resend.dev>"

# Langfuse (observability)
# LANGFUSE_SECRET_KEY=""
# LANGFUSE_PUBLIC_KEY=""
# LANGFUSE_BASE_URL="https://cloud.langfuse.com"
# LANGFUSE_PROJECT_ID=""

# OpenRouter
OPENROUTER_API_KEY=""

# Pinecone
PINECONE_API_KEY=""
PINECONE_INDEX="roboracer"
# Optional: index host URL from Pinecone console (recommended for reliability).
# Example: https://<index>-<id>.svc.<region>.pinecone.io
# PINECONE_INDEX_HOST=""
# Optional: Pinecone Inference embedding model id. Must match your index dimension.
# Example for 1024-d: llama-text-embed-v2
# PINECONE_EMBED_MODEL="llama-text-embed-v2"

# Scraper pipeline (knowledge base)
# Internal FastAPI service base URL (e.g. your Railway scraper service URL)
# SCRAPER_PIPELINE_BASE_URL="https://scraper-production-be08.up.railway.app"
# Optional: default finetune model id used by the pipeline's /prepare step
# SCRAPER_FINETUNE_MODEL=""
# Prompt used when finetune=true (markdown cleaner)
# FINETUNE_PROMPT=""

# Widget JWT
WIDGET_JWT_SECRET="change-me-in-production"
