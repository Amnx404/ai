// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth ────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Multi-tenant core ───────────────────────────────────────────────────────

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  orgId         String?
  org           Organization? @relation(fields: [orgId], references: [id])
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime      @default(now())
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  users     User[]
  sites     Site[]
}

model Site {
  id             String       @id @default(cuid())
  orgId          String
  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name           String
  // Branding
  primaryColor   String       @default("#6366f1")
  title          String       @default("Chat")
  greeting       String       @default("Hi! How can I help you today?")
  // The primary URL of the customer site this widget is embedded on.
  // Used for demo preview and favicon-based launcher icon fallback.
  primaryUrl     String       @default("")
  logoUrl        String?
  // Security
  allowedDomains String[]
  // RAG config
  allowedTopics  String[]
  modelId        String       @default("google/gemini-2.5-flash")
  temperature    Float        @default(0.3)
  pineconeIndex  String?
  pineconeNs     String?
  liveVersion    Int          @default(1)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  chatSessions   ChatSession[]
  analyticsEvents AnalyticsEvent[]
}

model ChatSession {
  id        String    @id @default(cuid())
  siteId    String
  site      Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  ipHash    String?
  createdAt DateTime  @default(now())
  messages  Message[]

  @@index([siteId, createdAt])
}

model Message {
  id         String      @id @default(cuid())
  sessionId  String
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role       String      // "user" | "assistant"
  content    String
  sources    Json?       // [{ title, url, score }]
  tokenCount Int?
  createdAt  DateTime    @default(now())

  @@index([sessionId])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  type      String   // "chat_start" | "message" | "out_of_scope"
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([siteId, createdAt])
}
